{
  "name": "splicer-lab",
  "productName": "Splicer Lab",
  "version": "3.0.0",
  "description": "A fast, fully local photo editor: library, non-destructive develop tools, precision crop with auto horizon leveling, clone stamp retouching, and size-targeted export.",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.4",
    "dcraw": "^1.0.3",
    "heic-convert": "^2.1.0",
    "exifr": "^7.1.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.splicerlab.photos",
    "productName": "Splicer Lab",
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.photography",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Graphics",
      "icon": "build/icon.png"
    },
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ]
  },
  "author": "Splicer"
}